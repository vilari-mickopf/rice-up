#! /bin/bash


is_installed() {
    package="$1"
    check="$(yay -Qs --color always $package | sed 's/\x1b\[[0-9;]*m//g' | grep "local/$package")"

    if [ -n "${check}" ]; then
        echo 0
        return
    fi

    echo 1

    return
}

install_packages() {
    to_install=()

    for pkg; do
        if [[ $(is_installed $pkg) == 0 ]]; then
            echo "$pkg is already installed."
            continue
        fi

        to_install+=($pkg)
    done

    if [[ ${to_install[@]} == "" ]]; then
        echo "All packages are already installed."
        return
    fi

    printf "Packages not installed:\n%s\n" ${to_install[@]}
    yay -S ${to_install[@]} --noconfirm
}

setup_yay() {
    package="yay"
    check="$(pacman -Qs --color always $package | sed 's/\x1b\[[0-9;]*m//g' | grep "local/$package")"

    if [ -z "${check}" ]; then
        echo "Installing yay - Yet another Yaourt"
        package="git"
        check="$(pacman -Qs --color always $package | sed 's/\x1b\[[0-9;]*m//g' | grep "local/$package")"
        if [ -n $check ]; then
            sudo pacman -S $package --noconfirm
        fi
        git clone https://aur.archlinux.org/yay.git $HOME/yay

        current_dir=$(pwd)

        cd $HOME/yay
        makepkg -si --noconfirm

        cd $current_dir
        rm -rf $HOME/yay
    fi

    echo
}

get_dotfiles() {
    echo "Collecting dotfiles"

    if [ $1 == false ]; then
        packages=("git")
        install_packages ${packages[@]}
    fi

    if [ -d $HOME/.dotfiles ]; then
        rm -rf $HOME/.dotfiles
    fi

    git clone https://github.com/f12markovic/dotfiles.git $HOME/.dotfiles
    git --git-dir=$HOME/.dotfiles/.git/ --work-tree=$HOME/ config status.showUntrackedFiles no

    echo
}

setup_i3() {
    echo "Setting i3-gaps"

    if [ $1 == false ]; then
        packages=("xorg" "curl" "i3-gaps" "i3blocks" "i3lock-color" "compton" \
                  "alsa" "alsa-utils" "alsa-firmware" "alsa-lib" "alsa-oss" \
                  "alsa-plugins" "pulseaudio" "pulseaudio-alsa" "pavucontrol" \
                  "arandr" "srandrd" "oblogout" "lxappearance" "rofi" "nautilus" \
                  "thunar" "feh" "rxvt-unicode" "light" "xorg-setxkbmap" \
                  "xorg-xset" "xorg-xsetroot" "xidlehook" "i3-battery-nagbar" \
                  "i3-scrot" "checkupdates+aur" "ranger" "wmctrl" "highlight" \
                  "volumeicon" "gnome-terminal" "rxvt-unicode" "dconf" "yad" \
                  "paper-icon-theme" "arc-icon-theme" "xcursor-vanilla-dmz" \
                  "gtk-engine-murrine" "gnome-themes-extra" "gnome-themes-standard" "arc-gtk-theme")

        install_packages ${packages[@]}
    fi

    cp $HOME/.dotfiles/.config/i3/config $HOME/.config/i3/
    cp $HOME/.dotfiles/.config/i3/i3blocks.conf $HOME/.config/i3/
    cp -r $HOME/.dotfiles/.config/i3/scripts $HOME/.config/i3/

    cp $HOME/.dotfiles/.config/compton.conf $HOME/.config/compton.conf

    bash -c "$(curl -fsSL https://raw.githubusercontent.com/denysdovhan/gnome-terminal-one/master/one-dark.sh)"

    cp $HOME/.dotfiles/.config/gtk-3.0/gtk.css $HOME/.config/gtk-3.0/gtk.css

    cp $HOME/.dotfiles/.Xresources $HOME/
    cp $HOME/.dotfiles/.extend.Xresources $HOME/

    cp -r $HOME/.dotfiles/.config/suckless $HOME/.config/
    $HOME/.config/suckless/suck-up

    user_dir=$HOME
    sudo ln -sf $user_dir/.config/oblogout.conf /etc/oblogout.conf

    git clone https://github.com/bruhensant/Adeos-ArchLabs.git $HOME/Adeos-ArchLabs
    sudo cp -r $user_dir/Adeos-ArchLabs/adeos-archlabs /usr/share/themes/
    rm -rf $HOME/Adeos-ArchLabs

    echo
}

setup_git() {
    echo "Setting git"

    if [ $1 == false ]; then
        packages=("git")
        install_packages ${packages[@]}
    fi

    cp $HOME/.dotfiles/.gitconfig $HOME/

    echo
}

setup_zsh() {
    echo "Setting zsh"

    if [ $1 == false ]; then
        packages=("wget" "curl" "fzf" "glib2" "zsh" "zsh-syntax-highlighting")
        install_packages ${packages[@]}
    fi

    echo "exit" | sh -c "$(curl -fsSL https://raw.githubusercontent.com/robbyrussell/oh-my-zsh/master/tools/install.sh)"
    chsh -s $(which zsh)

    current_dir=$(pwd)
    mkdir -p $HOME/.zsh
    cd $HOME/.zsh
    wget https://raw.githubusercontent.com/git/git/master/contrib/completion/git-completion.zsh
    mv git-completion.zsh _git
    cd $current_dir

    cp -r $HOME/.dotfiles/.config/zsh-custom-themes/ $HOME/.config/
    cp $HOME/.dotfiles/.zshrc $HOME/

    echo
}

setup_vim() {
    echo "Setting vim"

    if [ $1 == false ]; then
        packages=("neovim" "python" "python-neovim" "python-pynvim" "python2-pynvim"
                  "wl-clipboard" "xsel" "xclip" "ctags" "hasktags" "jupyter" "clang"
                  "cmake" "gdb" "gdb-common" "lldb" "python-flake8-debugger"
                  "python2-flake8-debugger" "octave")
        install_packages ${packages[@]}
    fi
    return

    mkdir -p $HOME/.vim/bundle
    if [ ! -d $HOME/.vim/bundle/Vundle.vim ]; then
        git clone https://github.com/VundleVim/Vundle.vim.git $HOME/.vim/bundle/Vundle.vim
    fi
    cp -r $HOME/.dotfiles/.vim/scripts $HOME/.vim/
    cp $HOME/.dotfiles/.vimrc $HOME/.vimrc

    # neovim - vim
    mkdir -p $HOME/.config/nvim/
    ln -sf $HOME/.vimrc $HOME/.config/nvim/init.vim

    mkdir -p $HOME/.local/share/nvim/
    ln -sf $HOME/.vim $HOME/.local/share/nvim/site

    nvim +PluginInstall +qa
    nvim +UpdateRemotePlugins +qa
    $HOME/.vim/bundle/YouCompleteMe/install.py
    cd $HOME/.vim/bundle/vimproc.vim && make

    cp $HOME/.dotfiles/.vim/bundle/vim-vebugger/autoload/vebugger.vim \
       $HOME/.vim/bundle/vim-vebugger/autoload/vebugger.vim

    cp $HOME/.dotfiles/.vim/bundle/vim-vebugger/autoload/vebugger.vim \
       $HOME/.vim/bundle/vim-vebugger/autoload/vebugger/std.vim

    cp $HOME/.dotfiles/.vim/bundle/vim-vebugger/autoload/vebugger.vim \
       $HOME/.vim/bundle/vim-vebugger/plugin/vebugger.vim

    cp -r $HOME/.dotfiles/.vim/bundle/vim-template $HOME/.vim/bundle/vim-template
    cp -r $HOME/.dotfiles/.vim/syntax $HOME/.vim/syntax
    cp -r $HOME/.dotfiles/.vim/plugin $HOME/.vim/plugin

    echo
}

setup_zathura() {
    echo "Setting zathura"

    if [ $1 == false ]; then
        packages=("zathura" "zathura-pdf-mupdf" "zathura-djvu" "zathura-ps")
        install_packages ${packages[@]}
    fi

    cp -r $HOME/.dotfiles/.config/zathura $HOME/.config/

    echo
}

setup_su() {
    echo "Setting su"

    user_dir=$HOME
    sudo ln -sf $user_dir/.zshrc /root/.zshrc
    sudo ln -sf $user_dir/.oh-my-zsh /root/.oh-my-zsh
    sudo ln -sf $user_dir/.config/zsh-custom-themes /root/.config/zsh-custom-themes
    sudo ln -sf $user_dir/.vimrc /root/.vimrc
    sudo ln -sf $user_dir/.vim /root/.vim
    sudo mkdir -p /root/.config/nvim/
    sudo ln -sf $user_dir/.vimrc /root/.config/nvim/init.vim
    sudo mkdir -p /root/.local/share/nvim/
    sudo ln -sf $user_dir/.vim /root/.local/share/nvim/site

    echo
}

setup_flake8() {
    echo "Setting flake8"

    if [ $1 == false ]; then
        packages=("flake8")
        install_packages ${packages[@]}
    fi

    cp $HOME/.dotfiles/.config/flake8 $HOME/.config/

    echo
}

setup_ncmpcpp() {
    echo "Setting ncmpcpp"

    if [ $1 == false ]; then
        packages=("mpd" "ncmpcpp")
        install_packages ${packages[@]}
    fi

    mkdir -p $HOME/.ncmpcpp/
    cp $HOME/.dotfiles/.ncmpcpp/config $HOME/.ncmpcpp/

    echo
}

setup_fonts() {
    if [ $1 == false ]; then

    echo "Installing fonts"

    adobe_fonts=$(pacman -Ssq adobe-source)
    packages=("ttf-ubuntu-font-family" "otf-font-awesome" "noto-fonts"
              "noto-fonts-cjk" "noto-fonts-emoji" "noto-fonts-extra"
              "awesome-terminal-fonts" "python-fontawesome" $adobe_fonts)
    install_packages ${packages[@]}

    fi

    echo
}

setup_apps() {
    setup_flake8 $1
    setup_ncmpcpp $1
    setup_zathura $1
    setup_fonts $1

    echo "Installing other apps"
    if [ $1 == false ]; then
        packages=("r" "pandoc" "pandoc-citeproc" "google-chrome" \
                  "skypeforlinux-stable-bin")
        install_packages ${packages[@]}
    fi
    sudo R -e "install.packages(\"rmarkdown\", repos = \"https://cloud.r-project.org/\")"

    echo
}

clean_up() {
    current_dir=$(pwd)

    cd $HOME/.dotfiles
    find . -maxdepth 1 -type d,f ! -iname .git -exec rm -rvf {} \; > /dev/null 2>&1

    cd $current_dir
}

help() {
    echo "help"
}


main()
{
    arg_list='--help -h --all --config-only -c --vim -v --zsh -z --apps -a --su -s --i3 -i --git -g'

    args=$@
    if [ $# -eq 0 ]; then
        args='--all'
    fi

    # Look for config flag
    config=false
    for arg in $args; do
        if [ $arg == "--config-only" ] || [ $arg == "-c" ]; then
            config=true
        fi
    done

    # If config is the only flag, assume --all --config-only
    if [[ $# -eq 1 && ($1 == "--config-only" || $1 == "-c") ]]; then
        args='--all'
    fi

    # Check all args
    for arg in $args; do
        if [[ $arg_list != *$arg* ]]; then
            help
            return
        fi
    done

    # Look for help flag
    for arg in $args; do
        if [ $arg == "--help" ] || [ $arg == "-h" ]; then
            help
            return
        fi
    done

    # Look for all flag
    for arg in $args; do
        if [ $arg == "--all" ]; then
            if [ $config == false ]; then
                setup_yay
            fi
            get_dotfiles $config
            setup_git $config
            setup_i3 $config
            setup_zsh $config
            setup_vim $config
            setup_su $config
            setup_apps $config
            clean_up
            return
        fi
    done

    # Look for others
    get_dotfiles $config
    for arg in $args; do
        if [ $arg == "--vim" ] || [ $arg == "-v" ]; then
            setup_vim $config
        elif [ $arg == "--i3" ] || [ $arg == "-i" ]; then
            setup_i3 $config
        elif [ $arg == "--apps" ] || [ $arg == "-a" ]; then
            setup_apps $config
        elif [ $arg == "--su" ] || [ $arg == "-s" ]; then
            setup_su $config
        elif [ $arg == "--zsh" ] || [ $arg == "-z" ]; then
            setup_zsh $config
        elif [ $arg == "--git" ] || [ $arg == "-g" ]; then
            setup_git $config
        fi
    done
    clean_up
}


main $@
